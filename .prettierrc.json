{
  "printWidth": 100,
  "tabWidth": 4,
  "useTabs": false,
  "singleQuote": true,
  "semi": true,
  "trailingComma": "none",
  "overrides": [
    {
      "files": "*.html",
      "options": { "tabWidth": 4 }
    },
    {
      "files": "*.md",
      "options": { "tabWidth": 2, "proseWrap": "always" }
    }
  ]
}
